.DS_Store

# Chromium checkout: huge (~100 GB), gclient-managed, and fully reproducible
# from PINNED_CHROMIUM via `gclient sync`. Never commit it. This also covers the
# build output under mac/src/out.
/mac/

# agent-backend (Python)
agent-backend/.venv/
agent-backend/.env
agent-backend/.chromium-profile/
# Per-provider CLI config + auth (hold subscription OAuth tokens — never commit).
agent-backend/claude-config/
agent-backend/codex-config/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
*.egg-info/
agent-backend/data/

# parental-control extension secret (written at launch / baked into the CRX)
extension/guardian-config.json

# extension CRX signing key (load-bearing: defines the extension ID — back it up,
# never commit) and the packed CRX + update manifest served to the kid browser.
agent-backend/.secrets/
agent-backend/.chromium-dist/

# observability stack local config (host paths/ports)
observability/.env

# superpowers brainstorm / visual-companion scratch artifacts (local only)
.superpowers/
