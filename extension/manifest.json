{
  "manifest_version": 3,
  "name": "Agentic Parental Control",
  "version": "0.2.7",
  "description": "Classifies pages for a 10-year-old and blocks unsuitable content via the local guardian backend.",
  "minimum_chrome_version": "114",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_title": "Screen time",
    "default_popup": "time-popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "block.html",
        "block.js",
        "block.css",
        "aegis-tokens.css",
        "aegis-components.css",
        "aegis-shield.svg",
        "fonts/*",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "webNavigation",
    "tabs",
    "scripting",
    "storage",
    "activeTab",
    "alarms",
    "idle"
  ],
  "host_permissions": ["<all_urls>"]
}
