{
  "uid": "guardian-browser-usage",
  "title": "Guardian — Browser Usage",
  "tags": ["guardian", "parental-control"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "profile",
        "label": "Profile",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(guardian_dwell_seconds_total, profile)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Blocks / min (15m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(guardian_classifications_total{verdict=\"block\"}[15m])) * 60" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cache hit ratio (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(guardian_cache_hits_total[1h])) / clamp_min(sum(rate(guardian_visits_total[1h])), 0.0001)" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Classify p95 (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(guardian_classification_duration_ms_bucket[10m])) by (le))" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Visits / min (15m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "decimals": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(guardian_visits_total[15m])) * 60" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Verdict rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (verdict) (rate(guardian_classifications_total[5m]))", "legendFormat": "{{verdict}}" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Category hit rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (category) (rate(guardian_category_hits_total[5m]))", "legendFormat": "{{category}}" }]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top domains (visits/s, 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "decimals": 4 }, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(15, sum by (host) (rate(guardian_visits_total[1h])))", "instant": true, "format": "table" }]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Dwell seconds/s by host (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "decimals": 4 }, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(15, sum by (host) (rate(guardian_dwell_seconds_total[1h])))", "instant": true, "format": "table" }]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Guardian events",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [{ "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{job=\"guardian\"}" }]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Chromium logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [{ "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{job=\"chromium\"}" }]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Screen time per day by profile",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 36 },
      "interval": "1d",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 6, "showPoints": "always", "lineInterpolation": "smooth" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (profile) (increase(guardian_dwell_seconds_total[1d]))", "legendFormat": "{{profile}}" }]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Website time (selected range)",
      "description": "Time-on-page per website for $profile over the panel's time range (Activity tab embeds this with a 48h range).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 45 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "align": "auto", "filterable": true } }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(20, sum by (host) (increase(guardian_dwell_seconds_total{profile=~\"$profile\"}[$__range])))", "instant": true, "format": "table" }]
    }
  ]
}
