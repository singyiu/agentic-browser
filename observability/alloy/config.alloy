// Grafana Alloy config for the agentic-browser observability stack.
// Logs: tail host files -> Loki. Metrics: scrape the host guardian -> Prometheus (in lgtm).
// Phases 2 (chromium) and 4 (transcripts) add their pipelines below.

// ---- Sinks (the all-in-one lgtm container, reached by compose service name) ----
loki.write "lgtm" {
  endpoint {
    url = "http://lgtm:3100/loki/api/v1/push"
  }
}

prometheus.remote_write "lgtm" {
  endpoint {
    url = "http://lgtm:9090/api/v1/write"
  }
}

// ---- Chain 1: guardian classification events (JSONL) -> Loki ----
local.file_match "guardian" {
  path_targets = [{
    __path__ = "/host/guardian-data/guardian_events.jsonl",
    job      = "guardian",
  }]
  sync_period = "10s"
}

loki.source.file "guardian" {
  targets    = local.file_match.guardian.targets
  forward_to = [loki.process.guardian.receiver]
}

loki.process "guardian" {
  forward_to = [loki.write.lgtm.receiver]

  // Parse the JSONL envelope and promote low-cardinality fields to stream labels.
  // url_key / reason / confidence stay in the log body (query with | json).
  stage.json {
    expressions = {
      event   = "event",
      verdict = "verdict",
    }
  }
  stage.labels {
    values = {
      event   = "event",
      verdict = "verdict",
    }
  }
}

// ---- Chain 2: raw Chromium process log -> Loki ----
local.file_match "chromium" {
  path_targets = [{
    __path__ = "/host/chrome_debug.log",
    job      = "chromium",
  }]
  sync_period = "15s"
}

loki.source.file "chromium" {
  targets    = local.file_match.chromium.targets
  forward_to = [loki.write.lgtm.receiver]
}

// ---- Chain 3: Claude Code transcripts -> Loki (secret-redacted) ----
// Disabled by default: compose mounts an empty dir at /host/claude-transcripts unless
// TRANSCRIPTS_DIR is set, so this glob matches nothing until you opt in.
local.file_match "transcripts" {
  path_targets = [{
    __path__ = "/host/claude-transcripts/*.jsonl",
    job      = "claude_transcript",
  }]
  sync_period = "30s"
}

loki.source.file "transcripts" {
  targets    = local.file_match.transcripts.targets
  forward_to = [loki.process.transcripts.receiver]
}

loki.process "transcripts" {
  forward_to = [loki.write.lgtm.receiver]

  // Redact secrets before the line reaches Loki. NOTE: stage.replace replaces the CAPTURE
  // GROUP with `replace` (not the whole match), so each secret is wrapped in a single group.
  // RE2 in double-quoted strings (backslashes doubled).
  stage.replace {
    expression = "(sk-ant-[A-Za-z0-9_\\-]{8,})"
    replace    = "[REDACTED:anthropic-key]"
  }
  stage.replace {
    expression = "(?i)bearer\\s+([A-Za-z0-9._\\-]+)"
    replace    = "[REDACTED:bearer]"
  }
  stage.replace {
    expression = "(AKIA[0-9A-Z]{16})"
    replace    = "[REDACTED:aws-key]"
  }
  // GUARDIAN_TOKEN-style long hex (also catches commit hashes/UUIDs — accepted, security-first).
  stage.replace {
    expression = "([0-9a-fA-F]{32,64})"
    replace    = "[REDACTED:hex]"
  }
  // Catch-all: redact the value that follows a sensitive key name.
  stage.replace {
    expression = "(?i)(?:password|secret|token|credential|api[_-]?key)[\\s:=\"'\\\\]{1,5}([^\\s,}\"]{3,})"
    replace    = "[REDACTED:kv]"
  }
}

// ---- Chain 4: scrape the host guardian's Prometheus metrics -> remote_write ----
prometheus.scrape "guardian" {
  targets = [{
    __address__ = "host.docker.internal:2948",
  }]
  scrape_interval = "15s"
  metrics_path    = "/metrics"
  forward_to      = [prometheus.remote_write.lgtm.receiver]
}
