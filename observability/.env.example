# Copy to observability/.env (git-ignored) and adjust if needed.

# Published ports (host:container)
GRAFANA_PORT=3000
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
ALLOY_UI_PORT=12345

# Absolute path to the repo root (used for read-only host log bind-mounts).
REPO_ROOT=/Users/singcheung/sing/agentic-browser

# Chromium process log (Phase 2) — must match the --log-file in scripts/launch-chromium.sh.
CHROMIUM_LOG_PATH=/Users/singcheung/sing/agentic-browser/agent-backend/.chromium-profile/chrome_debug.log

# Claude Code transcripts -> Loki (secret-redacted by Alloy). Disabled by default: when blank,
# the stack mounts an empty dir so nothing is ingested. To opt in, point this at your project's
# session dir (transcripts can still contain PII even after redaction):
#   TRANSCRIPTS_DIR=/Users/singcheung/.claude/projects/-Users-singcheung-sing-agentic-browser
TRANSCRIPTS_DIR=
