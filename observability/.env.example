# Copy to observability/.env (git-ignored) and adjust if needed.

# Published ports (host:container)
GRAFANA_PORT=3000
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
ALLOY_UI_PORT=12345

# Absolute path to the repo root (used for read-only host log bind-mounts).
REPO_ROOT=/Users/singcheung/sing/agentic-browser

# Chromium process log (Phase 2) — must match the --log-file in scripts/launch-chromium.sh.
CHROMIUM_LOG_PATH=/Users/singcheung/sing/agentic-browser/agent-backend/.chromium-profile/chrome_debug.log

# Claude Code transcript dir (Phase 4).
CLAUDE_PROJECTS_DIR=/Users/singcheung/.claude/projects/-Users-singcheung-sing-agentic-browser

# Ship Claude Code transcripts to Loki (Phase 4). Off by default — they may contain PII even
# after redaction. Set to "true" only after reviewing the redaction pipeline.
INGEST_TRANSCRIPTS=false
