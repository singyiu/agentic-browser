# Copy to .env and fill in. .env is git-ignored.

# Claude Max subscription auth. Generate with:  claude setup-token
# (Do NOT set ANTHROPIC_API_KEY — it would override the subscription and bill per-token.)
CLAUDE_CODE_OAUTH_TOKEN=

# CDP endpoint of the Chromium launched by scripts/launch-chromium.sh
CHROMIUM_CDP_URL=http://127.0.0.1:9222

# Model for the agent (optional; defaults to claude-sonnet-4-5)
AGENT_MODEL=claude-sonnet-4-5

# --- Parental control (guardian service) ---
# Shared secret the extension sends as X-Guardian-Token (any random string).
GUARDIAN_TOKEN=
# Service bind + classifier model (optional; defaults shown)
GUARDIAN_HOST=127.0.0.1
GUARDIAN_PORT=2947
GUARDIAN_MODEL=claude-haiku-4-5
# Seconds to wait for a verdict before failing open (a classification spawns a claude
# subprocess, so keep this generous; default 180).
GUARDIAN_CLASSIFY_TIMEOUT=180
# Set to true only after confirming screenshot/vision works on your subscription.
GUARDIAN_ENABLE_VISION=false
