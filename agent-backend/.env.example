# Copy to .env and fill in. .env is git-ignored.

# Claude Max subscription auth. Generate with:  claude setup-token
# (Do NOT set ANTHROPIC_API_KEY — it would override the subscription and bill per-token.)
CLAUDE_CODE_OAUTH_TOKEN=

# CDP endpoint of the Chromium launched by scripts/launch-chromium.sh
CHROMIUM_CDP_URL=http://127.0.0.1:9222

# Model for the agent (optional; defaults to claude-sonnet-4-5)
AGENT_MODEL=claude-sonnet-4-5

# --- Parental control (guardian service) ---
# Shared secret the extension sends as X-Guardian-Token (any random string). This is the single
# "default" profile's token; when GUARDIAN_PROFILES_PATH is set, per-teen tokens come from that
# file instead and this may be left blank.
GUARDIAN_TOKEN=
# Address the guardian binds (optional; default 127.0.0.1 = this machine only). To run the
# guardian and the browser on different computers on the same LAN, set 0.0.0.0 here on the
# guardian (parent) machine so it accepts connections from the browser machine.
GUARDIAN_HOST=127.0.0.1
GUARDIAN_PORT=2947
# URL the browser extension uses to reach the guardian (written into guardian-config.json by
# scripts/launch-chromium.sh). Default http://127.0.0.1:GUARDIAN_PORT. For a remote guardian,
# set this on the BROWSER (kid) machine to http://<guardian-LAN-ip>:2947 — GUARDIAN_TOKEN must
# match the guardian machine. See README "Running the browser and guardian on different computers".
GUARDIAN_ENDPOINT=
# Classifier model (optional; default shown)
GUARDIAN_MODEL=claude-haiku-4-5
# Seconds to wait for a verdict before failing open (a classification spawns a claude
# subprocess, so keep this generous; default 180).
GUARDIAN_CLASSIFY_TIMEOUT=180
# Set to true only after confirming screenshot/vision works on your subscription.
GUARDIAN_ENABLE_VISION=false
# Parental whitelist file (JSON array of entries; optional, default data/guardian_whitelist.json).
# Entry shapes: "www.youtube.com" (exact URL), "www.youtube.com/results*" (wildcard), and
# "BeyBlade anime" (natural-language topic). See README "Parental whitelist (guardian)".
GUARDIAN_WHITELIST_PATH=
# PIN the parent enters at http://127.0.0.1:2947/review to approve/reject access requests.
# Leave blank to disable the review feature. NEVER written into the extension config — the
# kid's browser holds GUARDIAN_TOKEN, so approval must require a secret it never receives.
GUARDIAN_PARENT_PIN=
# Access-requests file (JSON array; optional, default data/guardian_requests.json).
GUARDIAN_REQUESTS_PATH=
# Teen-profiles registry (JSON array of {name, token}; optional, default data/guardian_profiles.json).
# When present, ONE guardian governs several teens — each on its own LAN computer with its own
# GUARDIAN_TOKEN and its own whitelist/requests/cache under data/profiles/<name>/. With no file (or
# an empty list) the backend runs as a single "default" profile using GUARDIAN_TOKEN above. See
# README "Multiple teen profiles (LAN)" and guardian_profiles.example.json.
GUARDIAN_PROFILES_PATH=
