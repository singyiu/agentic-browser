# Copy to .env and fill in. .env is git-ignored.

# Claude Max subscription auth. Generate with:  claude setup-token
# (Do NOT set ANTHROPIC_API_KEY — it would override the subscription and bill per-token.)
CLAUDE_CODE_OAUTH_TOKEN=

# CDP endpoint of the Chromium launched by scripts/launch-chromium.sh
CHROMIUM_CDP_URL=http://127.0.0.1:9222

# Model for the agent (optional; defaults to claude-sonnet-4-5)
AGENT_MODEL=claude-sonnet-4-5
