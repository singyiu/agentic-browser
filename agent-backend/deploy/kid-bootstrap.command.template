#!/usr/bin/env bash
# Aegis — set up the locked browser on THIS child's Mac.
#
# You don't edit this file. The guardian generated it for one child and filled in its own network
# address. Double-click it (if macOS says it's from an unidentified developer, right-click → Open),
# and enter this Mac's password once when asked.
#
# What it does:
#   1. Downloads the Aegis browser from your guardian Mac and installs it to /Applications
#      (needs the Mac password; installing as root also means the kid can't delete it).
#   2. Locks it to the parental-control extension via a managed-preferences policy.
#   3. Launches it. From then on it reports to the guardian and enforces your rules.
#
# This file is safe to re-run (e.g. to repair the install).
set -euo pipefail

ENDPOINT="__ENDPOINT__"
PROFILE="__PROFILE__"
# SHA256 of the updater script this bootstrap downloads in step 5, baked in by the
# guardian at render time. This file travels out-of-band (AirDrop), so the pin lets us
# verify a download that otherwise rides plain LAN HTTP.
UPDATE_CHECK_SHA256="__UPDATE_CHECK_SHA256__"
POLICY_PLIST="/Library/Managed Preferences/org.chromium.Chromium.plist"
APPS_DIR="/Applications"
TMP_ZIP="${TMPDIR:-/tmp}/aegis-browser.zip"

bold(){ printf '\033[1m%s\033[0m\n' "$*"; }
ok(){   printf '  \033[32m✓\033[0m %s\n' "$*"; }
warn(){ printf '  \033[33m!\033[0m %s\n' "$*"; }
step(){ printf '\n\033[1m[%s/6]\033[0m \033[1m%s\033[0m\n' "$1" "$2"; }
die(){  printf '  \033[31m✗\033[0m %s\n' "$*" >&2; printf '\nSetup stopped. %s\n' "${2:-Please tell the parent.}" >&2; exit 1; }

json_field(){ grep -oE "\"$1\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | sed -E "s/.*:[[:space:]]*\"([^\"]*)\"/\1/" | head -1; }

# Defense-in-depth: the guardian validates these before substituting, but refuse to run
# a tampered or corrupt copy of this file outright.
case "$PROFILE" in
  ""|*[!A-Za-z0-9_-]*) die "This setup file looks corrupted (bad profile). Re-download it from the guardian." ;;
esac
case "$ENDPOINT" in
  http://*|https://*) : ;;
  *) die "This setup file looks corrupted (bad guardian address). Re-download it from the guardian." ;;
esac

clear 2>/dev/null || true
bold "Aegis — setting up this child's browser"
printf 'Child profile: %s\nGuardian:      %s\n' "$PROFILE" "$ENDPOINT"

# --- 1. Pre-flight -------------------------------------------------------------
step 1 "Checking this Mac"
[ "$(uname -s)" = "Darwin" ] || die "This setup is for macOS only."
command -v curl >/dev/null 2>&1 || die "curl is missing (it ships with macOS)."
if ! curl -fsS -m 5 "$ENDPOINT/health" >/dev/null 2>&1; then
  die "Can't reach the guardian at $ENDPOINT — make sure the guardian Mac is on and on this Wi-Fi."
fi
ok "Guardian is reachable."

# --- 2. Download the browser ---------------------------------------------------
step 2 "Downloading the Aegis browser"
MANIFEST="$(curl -fsSL "$ENDPOINT/dist/manifest.json" 2>/dev/null)" \
  || die "The guardian hasn't published the browser yet (ask the parent to run release-chromium.sh)."
SHA_EXPECTED="$(printf '%s' "$MANIFEST" | grep -oE '"sha256"[[:space:]]*:[[:space:]]*"[0-9a-f]{64}"' | grep -oE '[0-9a-f]{64}' | head -1 || true)"
APP_NAME="$(printf '%s' "$MANIFEST" | json_field app_name || true)"; APP_NAME="${APP_NAME:-Chromium.app}"
VERSION="$(printf '%s' "$MANIFEST" | json_field version || true)"
# The app name becomes an rm/install target under /Applications — never let a bad
# manifest smuggle in a path.
case "$APP_NAME" in
  */*|*..*) die "This guardian's browser manifest looks invalid (unsafe app name)." ;;
esac
curl -fSL --progress-bar "$ENDPOINT/dist/browser.zip" -o "$TMP_ZIP" || die "Download failed."
if [ -n "$SHA_EXPECTED" ]; then
  SHA_GOT="$(shasum -a 256 "$TMP_ZIP" | awk '{print $1}')"
  [ "$SHA_GOT" = "$SHA_EXPECTED" ] || die "Download is corrupted (checksum mismatch). Try again."
  ok "Downloaded ${VERSION:-browser} and verified its checksum."
else
  warn "No checksum in the guardian manifest — skipping verification."
fi

# --- 3. Install ----------------------------------------------------------------
step 3 "Installing to $APPS_DIR/$APP_NAME (enter this Mac's password if asked)"
# Install as root: works even when this account can't write /Applications, and a root-owned
# app is one the kid (a standard user) can't delete or swap out.
sudo rm -rf "$APPS_DIR/$APP_NAME" || die "Could not remove the previous install."
# Two extractors, judged by the RESULT (a runnable app bundle), not by either tool's exit code:
#   - ditto is fastest and restores symlinks, but when the zip carries AppleDouble/__MACOSX
#     sidecars, macOS 14+ refuses to restore the kernel-managed com.apple.provenance xattr and
#     ditto aborts ("Operation not permitted").
#   - unzip ignores that metadata (the app needs none — signatures live in the binaries) but
#     returns a NON-ZERO exit on benign warnings even when every file extracted, so its exit
#     status is not a reliable success signal — earlier this aborted a good install here.
# So: capture both tools' output to a log, and decide success only from the extracted bundle.
UNPACK_LOG="${TMPDIR:-/tmp}/aegis-unpack.log"; : >"$UNPACK_LOG"
main_exe_path(){
  local exe; exe="$(defaults read "$APPS_DIR/$APP_NAME/Contents/Info" CFBundleExecutable 2>/dev/null || echo Chromium)"
  printf '%s' "$APPS_DIR/$APP_NAME/Contents/MacOS/$exe"
}
app_ok(){ [ -d "$APPS_DIR/$APP_NAME" ] && [ -x "$(main_exe_path)" ]; }
if ! sudo ditto -x -k "$TMP_ZIP" "$APPS_DIR" >>"$UNPACK_LOG" 2>&1 || ! app_ok; then
  warn "ditto didn't cleanly unpack it — retrying with unzip."
  sudo rm -rf "$APPS_DIR/$APP_NAME"
  sudo unzip -qo "$TMP_ZIP" -d "$APPS_DIR" -x "__MACOSX/*" >>"$UNPACK_LOG" 2>&1 || true
fi
rm -f "$TMP_ZIP"
if ! app_ok; then
  tail -4 "$UNPACK_LOG" 2>/dev/null | while IFS= read -r line; do warn "unpack: $line"; done
  die "Could not unpack the browser into $APPS_DIR. The download may be incomplete — ask the parent to re-publish it (release-chromium.sh)."
fi
MAIN_EXE="$(main_exe_path)"
# Self-built browser → clear the download-quarantine flag so Gatekeeper allows it to launch.
sudo xattr -dr com.apple.quarantine "$APPS_DIR/$APP_NAME" 2>/dev/null || true
ok "Installed."

# --- 4. Lock it to the parental-control extension (needs the Mac password) -----
step 4 "Locking the browser (enter this Mac's password if asked)"
EXT_ID="$(curl -fsSL "$ENDPOINT/ext/$PROFILE/updates.xml" 2>/dev/null | grep -oE "appid='[a-p]{32}'" | grep -oE '[a-p]{32}' | head -1 || true)"
[ "${#EXT_ID}" -eq 32 ] || die "Could not read the extension id from the guardian."
UPDATE_URL="$ENDPOINT/ext/$PROFILE/updates.xml"
sudo mkdir -p "$(dirname "$POLICY_PLIST")"
sudo tee "$POLICY_PLIST" >/dev/null <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>ExtensionSettings</key>
  <dict>
    <key>*</key>
    <dict>
      <key>installation_mode</key><string>blocked</string>
      <key>blocked_install_message</key><string>Extensions are managed by your guardian.</string>
    </dict>
    <key>$EXT_ID</key>
    <dict>
      <key>installation_mode</key><string>force_installed</string>
      <key>update_url</key><string>$UPDATE_URL</string>
      <key>toolbar_pin</key><string>force_pinned</string>
    </dict>
  </dict>
  <!-- REQUIRED while extension updates are served over plain LAN HTTP: Chromium refuses a
       non-HTTPS update_url otherwise (loopback is exempt; LAN addresses are not). The CRX
       itself stays integrity-protected by its signature, which must match the pinned
       extension id above. Remove only after the guardian serves HTTPS — see SECURITY.md. -->
  <key>ExtensionAllowInsecureUpdates</key><true/>
</dict>
</plist>
PLIST
sudo plutil -lint "$POLICY_PLIST" >/dev/null || die "The policy file is invalid."
sudo chown root:wheel "$POLICY_PLIST"; sudo chmod 644 "$POLICY_PLIST"
sudo killall cfprefsd 2>/dev/null || true
ok "Locked to the parental-control extension."

# --- 5. Automatic updates ------------------------------------------------------
# This build can't auto-update a force-installed extension on its own, so install a tiny agent
# that checks the guardian hourly and refreshes the extension when the browser is closed.
step 5 "Setting up automatic updates"
SUPPORT="$HOME/Library/Application Support/Aegis"
AGENT_LABEL="com.aegis.kidbrowser"
AGENT_PLIST="$HOME/Library/LaunchAgents/$AGENT_LABEL.plist"
mkdir -p "$SUPPORT" "$HOME/Library/LaunchAgents"
if curl -fsSL "$ENDPOINT/dist/kid-update-check.sh" -o "$SUPPORT/kid-update-check.sh"; then
  if [ -n "$UPDATE_CHECK_SHA256" ]; then
    UPDATER_SHA_GOT="$(shasum -a 256 "$SUPPORT/kid-update-check.sh" | awk '{print $1}')"
    if [ "$UPDATER_SHA_GOT" != "$UPDATE_CHECK_SHA256" ]; then
      rm -f "$SUPPORT/kid-update-check.sh"
      die "The updater download failed its integrity check. Re-download this setup file from the guardian and run it again."
    fi
  fi
  chmod +x "$SUPPORT/kid-update-check.sh"
  cat >"$AGENT_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$AGENT_LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>$SUPPORT/kid-update-check.sh</string>
    <string>--endpoint</string><string>$ENDPOINT</string>
    <string>--profile</string><string>$PROFILE</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>StartInterval</key><integer>3600</integer>
  <key>ProcessType</key><string>Background</string>
  <key>StandardOutPath</key><string>$SUPPORT/update.log</string>
  <key>StandardErrorPath</key><string>$SUPPORT/update.log</string>
</dict>
</plist>
PLIST
  launchctl bootout "gui/$(id -u)/$AGENT_LABEL" 2>/dev/null || true
  if launchctl bootstrap "gui/$(id -u)" "$AGENT_PLIST" 2>/dev/null; then
    ok "Automatic updates enabled (checks hourly)."
  else
    warn "Could not start the updater agent — re-run this file later to enable auto-updates."
  fi
else
  warn "Could not download the updater — the browser still works; re-run this file later."
fi

# --- 6. Launch -----------------------------------------------------------------
step 6 "Starting the browser"
open -a "$APPS_DIR/$APP_NAME" || warn "Open $APPS_DIR/$APP_NAME yourself to finish."
printf '\n'
bold "✓ Done. This Mac is now set up for $PROFILE."
printf 'The browser checks every page with your guardian and enforces your rules.\n'
